# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Timeouts (seconds)
DEFAULT_TIMEOUT=10
AGGREGATOR_TIMEOUT=15

# Google providers (at least one required for /search/google)
SEARXNG_BASE_URL=
SERPBASE_API_KEY=
SERPER_API_KEY=

# --------------------------------------------------------------------------
# Optional API keys — omit to use public/unauthenticated access
# --------------------------------------------------------------------------

# Brave Search API (free tier: 2000 req/month)
# https://brave.com/search/api/
BRAVE_API_KEY=

# GitHub personal access token (raises rate limit from 60 to 5000 req/hour)
GITHUB_TOKEN=

# Stack Exchange API key (raises rate limit from 300 to 10,000 req/day)
# https://stackapps.com/apps/oauth/register
STACKEXCHANGE_API_KEY=

# Reddit (required — Reddit blocked unauthenticated access in 2023)
# Create a free 'script' app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# NCBI/PubMed API key (raises rate limit from 3 to 10 req/sec)
# https://ncbiinsights.ncbi.nlm.nih.gov/api-key-signup/
NCBI_API_KEY=

# Semantic Scholar API key (raises rate limit from 1 to 10 req/sec)
# https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# --------------------------------------------------------------------------
# Finance providers
# --------------------------------------------------------------------------

# Alpha Vantage (free tier: 25 req/day — ticker symbol search)
# https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Finnhub (free tier: 60 req/min — real-time stock search)
# https://finnhub.io/register
FINNHUB_API_KEY=

# Yahoo Finance uses an unofficial public endpoint — no key required.

# Comma-separated list of provider names to enable.
# Leave empty to enable all providers whose credentials are available.
# Example: ENABLED_PROVIDERS=google_serpbase,duckduckgo,wikipedia
ENABLED_PROVIDERS=

# Opt into high-friction HTML scrapers like Bing/Startpage/Yahoo/Qwant.
# These are disabled by default because they frequently fail from datacenter IPs.
ALLOW_UNSTABLE_PROVIDERS=false

# Max results to return per provider (per request)
MAX_RESULTS_PER_PROVIDER=10
